{
  "name": "viza",
  "version": "1.0.0",
  "description": "Visualize any code repository as an interactive drag-and-drop graph. Run 'viza build' to generate .vz files, then 'viza view' to explore.",
  "main": "src/index.js",
  "bin": {
    "viza": "./src/cli.js"
  },
  "scripts": {
    "start": "node src/cli.js",
    "build": "node src/cli.js build",
    "view": "node src/cli.js view"
  },
  "keywords": [
    "visualization",
    "repository",
    "code-analysis",
    "drag-and-drop",
    "graph"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "express": "^4.18.2",
    "glob": "^10.3.10",
    "open": "^8.4.2",
    "ora": "^5.4.1"
  }
}
